FROM ubuntu:22.04

ARG CLAUDE_VERSION=latest
ARG NODE_VERSION=20

ENV DEBIAN_FRONTEND=noninteractive
ENV HOME=/home/agent

RUN apt-get update && apt-get install -y \
    curl git ca-certificates gnupg \
    build-essential python3 python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Node.js
RUN curl -fsSL https://deb.nodesource.com/setup_${NODE_VERSION}.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# claude-code
RUN npm install -g @anthropic-ai/claude-code

# qwen-code (optional — best-effort)
RUN npm install -g qwen-code 2>/dev/null || true

# opencode (optional — best-effort)
RUN npm install -g opencode-ai 2>/dev/null || true

# Create agent home dir with correct permissions
RUN useradd -m -u 1000 -s /bin/bash agent \
    && mkdir -p /home/agent/.claude/projects \
    && chown -R agent:agent /home/agent

USER agent
WORKDIR /home/agent
