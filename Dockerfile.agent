# ─── stage 1: build chepherd binary ────────────────────────────────────────
# We bake chepherd into the agent image so claude-code can spawn the
# MCP-bridge subprocess (`chepherd mcp --url ...`) without chepherd
# having to bind-mount its own executable from the host (which doesn't
# work in the sibling-container architecture — the host podman daemon
# can't see paths inside the chepherd container).
FROM golang:1.25-alpine AS chepherd-builder
WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags '-s -w' -o /chepherd .

# ─── stage 2: agent runtime ────────────────────────────────────────────────
FROM ubuntu:22.04

ARG CLAUDE_VERSION=latest
ARG NODE_VERSION=20

ENV DEBIAN_FRONTEND=noninteractive
ENV HOME=/home/agent

RUN apt-get update && apt-get install -y \
    curl git ca-certificates gnupg \
    build-essential python3 python3-pip \
    && rm -rf /var/lib/apt/lists/*

# chepherd binary (for the MCP-bridge subprocess claude-code launches).
COPY --from=chepherd-builder /chepherd /usr/local/bin/chepherd

# Node.js
RUN curl -fsSL https://deb.nodesource.com/setup_${NODE_VERSION}.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# claude-code
RUN npm install -g @anthropic-ai/claude-code

# qwen-code — npm pkg @qwen-code/qwen-code ships binary `qwen`, but the
# agentcatalog slug expects /usr/local/bin/qwen-code. Pin + symlink to
# reconcile binary↔catalog. (Old `qwen-code` pkg name was wrong; #741.)
RUN npm install -g @qwen-code/qwen-code@0.18.1 \
 && ln -sf "$(command -v qwen)" /usr/local/bin/qwen-code

# gemini-cli — npm pkg @google/gemini-cli ships binary `gemini`. Symlink
# into /usr/local/bin to match the agentcatalog Binary path. (#741)
RUN npm install -g @google/gemini-cli@0.46.0 \
 && ln -sf "$(command -v gemini)" /usr/local/bin/gemini

# github copilot CLI — npm pkg @github/copilot ships binary `copilot`.
# Symlink into /usr/local/bin to match the agentcatalog Binary path. (#741)
RUN npm install -g @github/copilot@1.0.62 \
 && ln -sf "$(command -v copilot)" /usr/local/bin/copilot

# opencode — npm pkg opencode-ai ships binary `opencode`. Symlink into
# /usr/local/bin to match the agentcatalog Binary path. (#741)
RUN npm install -g opencode-ai \
 && ln -sf "$(command -v opencode)" /usr/local/bin/opencode

# Non-root agent user (UID 1000) — required by chepherd's spawn contract.
# Host UID 1000 in rootless Podman maps to container root; the actual
# agent user inside is UID 1000 ≠ container root. All credentials and
# state are provided through /run/secrets/ mounts owned via the U flag.
RUN useradd -m -u 1000 -s /bin/bash agent \
    && mkdir -p /home/agent/.claude/projects /run/secrets /home/agent/.local/bin \
    && ln -sf /usr/bin/claude /home/agent/.local/bin/claude \
    && chown -R agent:agent /home/agent
# ↑ /home/agent/.local/bin/claude symlink quiets Claude Code 2.1.160+'s
# self-doctor warning ("installMethod is native, but claude command not
# found at /home/agent/.local/bin/claude"). The npm-global install lands
# at /usr/bin/claude → symlink keeps both paths valid + the self-check
# happy without changing the actual install method.

# Entrypoint: link /run/secrets/claude-credentials to ~/.claude/.credentials.json
# so claude-code can find it at its hardcoded path. The mount is provided by
# chepherd at spawn time from its token vault; claude-code may refresh the
# token in-place but the vault remains source of truth — chepherd captures
# fresh tokens via PTY OAuth-URL detection (R5).
# #367 P0 — COPY --chmod=755 sets the mode at COPY time, independent
# of the host file's permissions, cache state, or any subsequent RUN
# step. Defensive against the regression where the running image had
# -rw-rw-r-- on /usr/local/bin/agent-entrypoint (OCI runtime permission
# denied, exit_code 126). The RUN chmod +x below remains as
# belt-and-suspenders.
COPY --chmod=755 scripts/agent-entrypoint.sh /usr/local/bin/agent-entrypoint
# #273 — defensive removal of any leftover `chepherd-agent-entrypoint`
# from older base-image layers. A previous build flow installed the
# script under that name + the ENTRYPOINT was switched to
# `agent-entrypoint` without removing the old file. Result: walker /
# operator probes that `cat /usr/local/bin/chepherd-agent-entrypoint`
# returned the post-#257 contents BUT the actual ENTRYPOINT runs the
# stale `agent-entrypoint`. This RUN line guarantees the leftover is
# gone on every fresh build.
RUN chmod +x /usr/local/bin/agent-entrypoint \
 && rm -f /usr/local/bin/chepherd-agent-entrypoint \
 && test -x /usr/local/bin/agent-entrypoint \
    || { echo "#367 BUILD FAILURE: agent-entrypoint missing exec bit despite RUN chmod"; ls -la /usr/local/bin/agent-entrypoint; exit 1; }

USER agent
WORKDIR /home/agent
ENTRYPOINT ["/usr/local/bin/agent-entrypoint"]
