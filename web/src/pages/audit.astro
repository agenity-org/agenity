---
// v0.9.4 audit dashboard route — #490 Wave AU3.
//
// Consumes AU2's GET /api/v1/audit/events. Filter UI + per-agent view
// + 5s polling refresh. URL: /audit (or /audit?agent=<sid>).
//
// Top-level route, not /v0.9.4/audit, because:
//   1. Astro dev-server file watcher 404s on dotted subdirectories
//      (verified empirically — v0.9.4/audit.astro yielded 404 in
//      dev; single-file v0.9.3.astro etc. work).
//   2. Audit log is a global operator tool, not version-specific.
//      /audit ages well across releases.
//
// AuthGate is NOT applied — auth flows via /api/v1/* middleware
// (Bearer token sent on every fetch via the operator's existing
// authenticated session). A future Wave can swap to AuthGate.
//
// Refs #490 #489 V0.9.2-ARCH §10 §13.
import AuditLog from '../components/v09/AuditLog.svelte';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>chepherd v0.9.4 — audit log</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      html,
      body {
        margin: 0;
        padding: 0;
        height: 100vh;
        background: #0a0a0a;
      }
      body {
        font-family: ui-sans-serif, system-ui, sans-serif;
        color: #f5f5f5;
      }
    </style>
  </head>
  <body>
    <AuditLog client:load />
  </body>
</html>
