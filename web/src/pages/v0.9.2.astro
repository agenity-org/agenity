---
// v0.9.2 dashboard route — release v0.9.2 of chepherd.
//
// What's new vs /v0.9.1/:
//   - A2A SendMessage HTTP endpoint (#208 / PR #215) — /jsonrpc
//     surfaces server-to-server messaging on the same listen addr
//     as the dashboard.
//   - Persistence abstraction (#208 / PR #209-#211): SessionRepository
//     + AgentRepository backed by SQLite or Postgres; runtime + shepherd
//     read/write through repositories.
//   - Spawn ↔ SessionRepository wire-up (#208 / PR #216): shepherd's
//     tick loop discovers runtime-spawned sessions.
//   - Runtime.GetByContextID (#208 / PR #217): A2A contextId accepts
//     either the @-name or the full session ID.
//   - Spawn auth-env propagation (#218 / PR #221): vault.claude-oauth
//     → CLAUDE_CODE_OAUTH_TOKEN per spawn.
//
// URL versioning rule (operator 2026-05-28): each release ships its
// own /vMAJOR.MINOR.PATCH/ route. Minor.patch bumps from here on
// unless the operator says otherwise.
//
// This route mounts the existing Workspace shell with version="v0.9.2"
// so the header brand badge displays the right release (#223).
import Workspace from '../components/v08/Workspace.svelte';
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>chepherd v0.9.2 — workspace</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      html, body { margin: 0; padding: 0; height: 100vh; overflow: hidden; background: #0a0a0a; }
      body { font-family: ui-sans-serif, system-ui, sans-serif; color: #f5f5f5; }
    </style>
  </head>
  <body>
    <Workspace client:load version="v0.9.2" />
  </body>
</html>
