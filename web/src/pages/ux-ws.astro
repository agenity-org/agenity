---
// ux-ws — the WORKSPACES dashboard layout (codename "ws").
//
// An OS-virtual-desktop model (like Windows / Ubuntu workspaces): each
// WORKSPACE is a named, saved, fully-composed split-tree of panes. A header
// strip lists the workspaces; Ctrl+1..9 jump, Ctrl+` / Ctrl+Tab cycle, and
// every workspace + layout persists per-user to localStorage. Self-contained
// under web/src/components/ws/ so it never collides with the calm / tabs /
// v09 trees. Mounts its own root component (which carries its own login gate +
// fetch-auth wrapper), mirroring the client:load hydration used by /ux-calm/.
import Dashboardws from '../components/ws/Dashboardws.svelte';
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>chepherd — workspaces</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      html, body { margin: 0; padding: 0; height: 100vh; overflow: hidden; }
      body { font-family: ui-sans-serif, system-ui, sans-serif; }
    </style>
  </head>
  <body>
    <Dashboardws client:load version="ws" />
  </body>
</html>
