---
// ux-calm — the "calm" dashboard experiment.
//
// A spacious, focus-first reimagining of the chepherd workspace by an
// independent UX track. Self-contained under web/src/components/calm/ so
// it never collides with the canonical v09 tree. Mounts its own root
// component (which carries its own login gate + fetch-auth wrapper),
// mirroring the client:load hydration used by /v0.9.4/.
import Dashboardcalm from '../components/calm/Dashboardcalm.svelte';
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>chepherd — calm</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      html, body { margin: 0; padding: 0; height: 100vh; overflow: hidden; }
      body { font-family: ui-sans-serif, system-ui, sans-serif; }
    </style>
  </head>
  <body>
    <Dashboardcalm client:load version="calm" />
  </body>
</html>
