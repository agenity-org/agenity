---
// ux-mission — "mission control" dashboard experiment route.
//
// Self-contained UX revamp (codename: mission). Mounts the root component
// Dashboardmission.svelte client-side with full interactivity, mirroring
// how /v0.9.4/ mounts AuthGate (client:load) — except this dashboard owns
// its own auth gate + theme + data layer internally, so there's no
// separate wrapper component to import.
import Dashboardmission from '../components/mission/Dashboardmission.svelte';
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>chepherd — mission control</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      html, body { margin: 0; padding: 0; height: 100vh; overflow: hidden; }
      body { font-family: ui-sans-serif, system-ui, sans-serif; }
    </style>
  </head>
  <body>
    <Dashboardmission client:load version="v0.9.4" />
  </body>
</html>
