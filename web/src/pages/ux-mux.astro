---
// ux-mux — the "mux" dashboard revamp route.
//
// An independent, terminal-native (tmux-style) take on the chepherd
// multi-agent dashboard. Self-contained under web/src/components/mux/.
//
// Mirrors v0.9.4.astro's mounting shape: imports the root Svelte 5
// component and hydrates it client:load with full interactivity. The
// component carries its OWN auth gate (token prompt + ?token= ingest +
// chepherd-401 handling), so unlike v0.9.4 it doesn't need the shared
// AuthGate wrapper — keeping this route fully isolated from the other
// experts' component trees.
import Dashboardmux from '../components/mux/Dashboardmux.svelte';
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>chepherd · mux</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      html, body { margin: 0; padding: 0; height: 100vh; overflow: hidden; background: #0a0b0d; }
      body { font-family: ui-monospace, "JetBrains Mono", monospace; color: #e8eaed; }
    </style>
  </head>
  <body>
    <Dashboardmux client:load version="v0.9.4" />
  </body>
</html>
