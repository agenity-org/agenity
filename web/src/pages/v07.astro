---
// v0.6 dashboard route — composable workspace canvas. Talks to the
// v0.6 runtime via /api/v1 (Vite dev proxy forwards to whichever runtime
// the dashboard is configured to point at).
import Workspace from '../components/v07/Workspace.svelte';
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>chepherd v0.7 — workspace</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      html, body { margin: 0; padding: 0; height: 100vh; overflow: hidden; background: #0a0a0a; }
      body { font-family: ui-sans-serif, system-ui, sans-serif; color: #f5f5f5; }
    </style>
  </head>
  <body>
    <Workspace client:load />
  </body>
</html>
