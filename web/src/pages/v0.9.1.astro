---
// v0.9.1 dashboard route — release v0.9.1 of chepherd.
//
// What's new vs /v0.9.0/:
//   - Canon entity (#198) wired as Layer 1 of the 3-layer agent context
//   - Roles catalog (12 builtins) replaces the v0.9.0 role-skills mashup
//   - Skills rebuilt as 10 LEAN engineering practices (#194)
//   - Templates rebuilt on Fibonacci sizing: solo(1)/pair(2)/trio(3)/
//     scrum(5)/squad(8)/custom(0)
//   - Code Reviewer Pair-conditional clause (absorbs team-orchestration
//     + process-coaching in 2-person teams)
//   - Agent persistence: RoleID + OwnedSkillsScope fields
//
// URL versioning rule (operator 2026-05-28): each release ships its
// own /vMAJOR.MINOR.PATCH/ route. Minor.patch bumps from here on
// unless the operator says otherwise.
//
// Stage 1/3/4 visual updates for the new Slot shape are pending
// (#114). This route mounts the existing Workspace shell so the
// dashboard renders; new wizard surfaces ship in subsequent commits.
import Workspace from '../components/v08/Workspace.svelte';
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>chepherd v0.9.1 — workspace</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      html, body { margin: 0; padding: 0; height: 100vh; overflow: hidden; background: #0a0a0a; }
      body { font-family: ui-sans-serif, system-ui, sans-serif; color: #f5f5f5; }
    </style>
  </head>
  <body>
    <Workspace client:load />
  </body>
</html>
